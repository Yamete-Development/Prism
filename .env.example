# Redis Connection Settings
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your_password_here

# Redis Streams for Python -> Elixir
REDIS_STREAM_FAST=discord:fanout:stream:fast
REDIS_STREAM_SLOW=discord:fanout:stream:slow

# Redis Stream for Elixir -> Python (Callbacks)
REDIS_CALLBACK_STREAM=discord:fanout:callbacks

# Redis Consumer Group
REDIS_GROUP=elixir_fanout_pool

# The Global Rate Limiter: Maximum batches allowed per second per lane.
# 1 batch = 50 webhook targets.
# Defaults to 1 (50 reqs/sec per lane). Increase this ONLY if Discord raises your global limit!
MAX_BATCHES_PER_SEC=1

# Broadway Concurrency: Maximum number of batches to process concurrently per lane.
# Default is 50. This controls how many batches are "in-flight" inside the pipeline at once.
# PRISM_BROADWAY_CONCURRENCY=50

# Batch Max Concurrency: Maximum number of HTTP requests to fire concurrently per batch.
# Default is 80.
# PRISM_BATCH_MAX_CONCURRENCY=80

# Backpressure: Per-node Cloudflare IP-block cooldown.
# When a worker receives a Cloudflare 429 (IP-level block), it records the
# retry_after delay and sleeps between batches for that duration. Healthy workers
# on other IPs continue processing while this node cools down.
# Defaults to true. Set to "false" to disable.
# PRISM_BACKPRESSURE_ENABLED=true

# Retry Pipeline Rate Limit: Max batches/sec for the background retry pipeline.
# This controls how fast failed webhook deliveries are retried independently of
# the main processing lanes.
# Default is 50.
# PRISM_RETRY_MAX_BATCHES_PER_SEC=50

# Retry Pipeline Concurrency: Max concurrent batches for the background retry pipeline.
# Default is 50.
# PRISM_RETRY_BROADWAY_CONCURRENCY=50

# Real-time SSE Streams
# Set to "true" to publish broadcast events to Redis Pub/Sub for Web UI SSE.
# PRISM_REDIS_SSE_ENABLED=false
# PRISM_REDIS_SSE_TOPIC_PREFIX=dashboard:stream:hub:
