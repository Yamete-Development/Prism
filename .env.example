# ── Redis Connection ────────────────────────────────────────────────

REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=your_password_here

# ── Event Bus (Input & Output) ───────────────────────────────────────
# Optional (Default: http://localhost:8081)
SCHEMA_REGISTRY_URL=http://localhost:8081

# Redis Configuration (Required)
# Transport format for Job streams (redis, kafka). Defaults to redis.ule path)
# EVENT_BUS_TRANSPORT=redis

# Kafka Brokers (comma-separated, used if transport is kafka)
# KAFKA_BROKERS=localhost:9092

# Jobs lane stream (Input topic/key from the bot)
PRISM_STREAM_JOBS=prism.stream.jobs

# Consumer group name for the jobs lane
PRISM_CONSUMER_GROUP=prism:cg:fanout

# Shared event stream key (Output for callbacks)
# EVENTS_STREAM=events.bus

# Dead-letter queue stream key
# EVENTS_DLQ_STREAM=events.bus.dlq

# Event stream MAXLEN (~ approximate, default: 100000)
# EVENTS_STREAM_MAXLEN=100000

# Event source identifier for this service (default: /prism)
# EVENT_SOURCE=/prism

# Max delivery attempts before DLQ (default: 3)
# EVENT_BUS_MAX_RETRIES=3

# Base backoff for retries in ms (doubles each attempt, default: 1000)
# EVENT_BUS_RETRY_BACKOFF_BASE_MS=1000

# Maximum backoff cap in ms (default: 30000)
# EVENT_BUS_RETRY_BACKOFF_MAX_MS=30000

# Messages per XREADGROUP batch (default: 10)
# EVENT_BUS_CONSUMER_BATCH_SIZE=10

# XREADGROUP block timeout in ms (default: 3000)
# EVENT_BUS_CONSUMER_BLOCK_MS=3000

# XAUTOCLAIM idle threshold in ms (default: 30000)
# EVENT_BUS_STALE_CLAIM_IDLE_MS=30000

# Interval between XAUTOCLAIM runs in ms (default: 60000)
# EVENT_BUS_STALE_CLAIM_INTERVAL_MS=60000

# CloudEvent type for the callback stream (batch status callbacks)
# EVENT_BUS_CALLBACK_TYPE=prism.callback

# CloudEvent type for broadcast completion (sent to shared events:bus)
# EVENT_BUS_BROADCAST_TYPE=prism.broadcast.completed

# ── Internal Redis Queues (Retries & Rate Limits) ────────────────────

# Prism requires Redis for internal state (delayed queues, rate limits, dead message cache).
# Even if EventBus transport is Kafka, these settings are used for Redis.

# Retry stream for failed webhook deliveries (Always Redis)
# REDIS_RETRY_STREAM=prism.stream.retries

# ── Redix Pool ───────────────────────────────────────────────────────

# Number of Redix connections in the pool (default: 5)
# PRISM_REDIX_POOL_SIZE=5

# ── Delayed Queue ────────────────────────────────────────────────────

# ZSET key for the delayed retry queue
# PRISM_DELAYED_ZSET_KEY=prism:delayed

# PubSub channel for scheduler wakeup events
# PRISM_PUBSUB_CHANNEL=prism:wakeup

# Error retry delay (ms) when the delayed scheduler's Redis call fails
# PRISM_DELAYED_SCHEDULER_ERROR_RETRY_MS=5000

# ── Finch HTTP Pool ──────────────────────────────────────────────────

# Total Finch HTTP connections in the pool (default: 50)
# PRISM_FINCH_POOL_COUNT=50

# HTTP receive timeout in ms (default: 30000)
# PRISM_FINCH_RECEIVE_TIMEOUT_MS=30000

# HTTP pool timeout in ms (default: 10000)
# PRISM_FINCH_POOL_TIMEOUT_MS=10000

# HTTP idle timeout in ms (default: 60000)
# PRISM_FINCH_IDLE_TIMEOUT_MS=60000

# HTTP keepalive in ms (default: 30000)
# PRISM_FINCH_KEEPALIVE_MS=30000

# Discord API base URL (for self-hosted Discord-compatible servers)
# PRISM_DISCORD_BASE_URL=https://discord.com

# ── Broadway Tuning ──────────────────────────────────────────────────

# Max concurrent batches per fanout lane (default: 50)
# PRISM_BROADWAY_CONCURRENCY=50

# Messages fetched per XREADGROUP round-trip per processor (default: 50)
# Higher = fewer serial Redis calls during bursts. Trade-off: larger in-flight buffer.
# PRISM_BROADWAY_MAX_DEMAND=50

# Processors request refill when demand drops to this level (default: 5)
# Keeps the producer pipeline warm instead of waiting for full drain.
# PRISM_BROADWAY_MIN_DEMAND=5

# Number of parallel FanoutBroadway instances (default: 3)
# Each instance owns its own Redis connection, eliminating the single-connection
# fetch bottleneck. All instances share the same consumer group.
# PRISM_FANOUT_PRODUCER_COUNT=3

# Max concurrent HTTP requests per batch (default: 80)
# PRISM_BATCH_MAX_CONCURRENCY=80

# Max concurrent batches for the retry lane (default: 10)
# PRISM_RETRY_BROADWAY_CONCURRENCY=10

# Receive interval in ms for each lane
# PRISM_JOBS_RECEIVE_INTERVAL=5
# PRISM_RETRY_RECEIVE_INTERVAL=100

# Warning threshold for high queue time (ms) (default: 2000)
# PRISM_QUEUE_TIME_WARN_MS=2000

# Task.async_stream timeout per target (ms) (default: 60000)
# PRISM_TASK_TIMEOUT_MS=60000

# Max in-flight async batches before re-enqueueing to delayed queue (default: 300)
# PRISM_MAX_ASYNC_BATCHES=300

# Enable/disable preflight Redis batching (pipelines checkpoint + rate-limit reads before fan-out)
# PRISM_PREFLIGHT_BATCHING_ENABLED=true

# ── Backpressure ─────────────────────────────────────────────────────

# Enable/disable per-node Cloudflare IP-block cooldown
# PRISM_BACKPRESSURE_ENABLED=true

# Maximum backoff for Cloudflare blocks (ms) (default: 600000 = 10 min)
# PRISM_BACKPRESSURE_MAX_BACKOFF_MS=600000

# Minimum cooldown window after a Cloudflare block (ms) (default: 60000 = 1 min)
# PRISM_BACKPRESSURE_MIN_COOLDOWN_MS=60000

# ── Invalid Request Tracker ──────────────────────────────────────────

# Sliding window for invalid request counting (ms) (default: 600000 = 10 min)
# PRISM_INVALID_REQUEST_WINDOW_MS=600000

# Threshold at which outbound HTTP is deferred (default: 9500)
# PRISM_INVALID_REQUEST_BACKPRESSURE_THRESHOLD=9500

# Critical threshold for warning logs (default: 10000)
# PRISM_INVALID_REQUEST_CRITICAL_THRESHOLD=10000

# ── Rate Limit Bucket ────────────────────────────────────────────────

# TTL for rate-limit bucket hash entries (seconds) (default: 3600)
# PRISM_BUCKET_HASH_TTL_SECONDS=3600

# ── Retry Parameters ─────────────────────────────────────────────────

# Base delay for server error (5xx) retries (ms) (default: 2000)
# PRISM_SERVER_ERROR_BASE_DELAY_MS=2000

# Max retry attempts for server errors (default: 3)
# PRISM_SERVER_ERROR_MAX_RETRIES=3

# Base delay for network error retries (ms) (default: 1000)
# PRISM_NETWORK_ERROR_BASE_DELAY_MS=1000

# Max retry attempts for network errors (default: 5)
# PRISM_NETWORK_ERROR_MAX_RETRIES=5

# Max retry attempts for message_not_found (10008) errors (default: 5)
# PRISM_MESSAGE_NOT_FOUND_MAX_RETRIES=5

# Threshold above which pre-flight rate limits defer to retry queue (ms) (default: 10000)
# PRISM_RATE_LIMIT_DEFER_THRESHOLD_MS=10000

# Checkpoint TTL (seconds) (default: 86400 = 24 hours)
# PRISM_CHECKPOINT_TTL_SECONDS=86400

# ── Feature Gates ────────────────────────────────────────────────────

# Enable/disable dead message cache (prevents retrying known-deleted messages)
# PRISM_DEAD_MESSAGE_CACHE_ENABLED=true

# Enable/disable key expansion (maps short keys back to full names)
# PRISM_KEY_EXPANSION_ENABLED=true

# Enable/disable cancel checker (checks Redis for cancelled source messages)
# PRISM_CANCEL_CHECKER_ENABLED=true

# Enable/disable stream trimmer (periodic XTRIM of processed messages)
# PRISM_STREAM_TRIMMER_ENABLED=true

# ── Dead Message Cache ───────────────────────────────────────────────

# Redis key prefix for dead message entries
# PRISM_DEAD_MESSAGE_CACHE_PREFIX=prism:dead:

# TTL for dead message cache entries (seconds) (default: 1800 = 30 min)
# PRISM_DEAD_MESSAGE_CACHE_TTL=1800

# ── Cancel Checker ───────────────────────────────────────────────────

# Redis key prefix for cancel entries
# PRISM_CANCEL_PREFIX=prism:cancel:

# ── Stream Trimmer ───────────────────────────────────────────────────

# Trim interval in ms (default: 30000 = 30s)
# PRISM_STREAM_TRIM_INTERVAL_MS=30000

# ── Callbacks ────────────────────────────────────────────────────────

# Include parent_message_id in execute callback payloads
# PRISM_INCLUDE_PARENT_MESSAGE_ID=true

# ── Reply Index ──────────────────────────────────────────────────────

# Enable/disable durable Redis reply index
# PRISM_REPLY_INDEX_ENABLED=true

# Redis key prefix for reply delivery state
# PRISM_REPLY_INDEX_PREFIX=prism

# TTL for reply index keys (seconds) (default: 604800 = 7 days)
# PRISM_REPLY_INDEX_TTL_SECONDS=604800

# ── Cluster ──────────────────────────────────────────────────────────

# Cluster topology name (atom, default: prism_cluster)
# PRISM_CLUSTER_TOPOLOGY=prism_cluster

# ── Worker ───────────────────────────────────────────────────────────

# Unique worker ID for Redis key scoping (auto-generated if unset)
# PRISM_WORKER_ID=


